# ──────────────────────────────────────────────
# ErfanWeb — Next.js Frontend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and adjust per environment.

# ── Site ──
FRONT_URL=http://localhost:3000
WEBSITE_URL=http://localhost:3000
PORT=4000
DOMAIN=studioarman.site

# ── Localization ──
# Comma-separated list of supported locales
LOCALES=fa
# Default locale (must be one of LOCALES)
DEFAULT_LOCALE=fa

# ── Product / Favicon Set ──
# Selects which favicon set to use from public/favicon-sets/{SITE_ID}/
# Each product/deployment sets this to its own ID.
# Default: site-a
NEXT_PUBLIC_SITE_ID=site-a

# ── Strapi API (server-side, runtime-only, NOT inlined) ──
# Used by fetchContentType.ts, lib/auth.ts, next.config.mjs (redirects).
# Local (Docker): http://host.docker.internal:8080
# Server:         https://studioarman.site:2087
STRAPI_INTERNAL_URL=https://studioarman.com

# ── Strapi API (client-side, NEXT_PUBLIC_ = inlined at build time) ──
# Used by auth-context.tsx for login/register from the browser.
# Local: http://localhost:8080
# Server: https://studioarman.site:2087
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Strapi Media URL (browser-facing images, inlined at build time) ──
# Used by strapiImage.ts, strapi-image.tsx, and all dynamic-zone components.
# Local: http://localhost:8080
# Server: https://studioarman.site:2087
NEXT_PUBLIC_STRAPI_URL=http://localhost:8080

# ── Backend URL (legacy) ──

# ── Image hostname for next.config remotePatterns ──
IMAGE_HOSTNAME=localhost:8080

# ── Strapi ports ──
BACK_PORT=8080

# ── ALTCHA (self-hosted bot detection) ──
# Generate a random secret: openssl rand -hex 32
ALTCHA_HMAC_SECRET=your-random-secret-here

# ── Auth ──
PREVIEW_SECRET=tobemodified

# ── Google Analytics ──
# Set your GA4 measurement ID (starts with G-)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Enamad Trust Seal ──
# Set to "true" to show the Enamad badge in the footer
NEXT_PUBLIC_SHOW_ENAMAD=false
# Full URL to the Enamad trust seal
NEXT_PUBLIC_ENAMAD_URL=https://trustseal.enamad.ir/?id=690945&Code=rgk8cRpwyv7qi7lWVM6noaAn9SiQzaP9

# ── Notification Provider (contact form) ──
# Options: bale, telegram, web3forms
NOTIFICATION_PROVIDER=bale

# Bale bot (used when NOTIFICATION_PROVIDER=bale)
# Get token from @botfather on Bale
BALE_BOT_TOKEN=
BALE_ADMIN_CHAT_ID=

# Telegram bot (used when NOTIFICATION_PROVIDER=telegram)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Web3Forms (used when NOTIFICATION_PROVIDER=web3forms)
# Get access key from https://web3forms.com
CONTACT_EMAIL_ACCESS_KEY=
CONTACT_EMAIL=

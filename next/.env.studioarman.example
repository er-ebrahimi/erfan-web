# ── Site ──
WEBSITE_URL=http://localhost:3000
PORT=4000
DOMAIN=strapi.studioarman.com
FRONT_URL=https://studioarman.com
# ── Strapi API (server-side, runtime-only, NOT inlined) ──
# Used by fetchContentType.ts, lib/auth.ts, next.config.mjs (redirects).
# Local override: STRAPI_INTERNAL_URL=http://host.docker.internal:8080
STRAPI_INTERNAL_URL=https://strapi.studioarman.com

# ── Strapi API (client-side, NEXT_PUBLIC_ = inlined at build time) ──
# Used by auth-context.tsx for login/register from the browser.
# Local override: NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=https://strapi.studioarman.com

# ── Strapi Media URL (browser-facing images, inlined at build time) ──
# Used by strapiImage.ts, strapi-image.tsx, and all dynamic-zone components.
# Local override: NEXT_PUBLIC_STRAPI_URL=http://localhost:8080
NEXT_PUBLIC_STRAPI_URL=https://strapi.studioarman.com

# ── Backend URL (legacy) ──
BACKEND_URL=https://strapi.studioarman.com

# ── Image hostname for next.config remotePatterns ──
IMAGE_HOSTNAME=strapi.studioarman.com


# ── ALTCHA (self-hosted bot detection) ──
ALTCHA_HMAC_SECRET=your-random-secret-here

# ── Auth ──
PREVIEW_SECRET=tobemodified

# ── Google Analytics ──
NEXT_PUBLIC_GA_ID=

# ── Google Tag Manager ──
NEXT_PUBLIC_GTM_ID=

# ── Enamad Trust Seal ──
NEXT_PUBLIC_SHOW_ENAMAD=false
NEXT_PUBLIC_ENAMAD_URL=

# ── Notification Provider ──
NOTIFICATION_PROVIDER=bale

# Bale bot
BALE_BOT_TOKEN=
BALE_ADMIN_CHAT_ID=

# Web3Forms (fallback)
CONTACT_EMAIL_ACCESS_KEY=
CONTACT_EMAIL=

# ── Localization ──
# Comma-separated list of supported locales
LOCALES=fa
# Default locale (must be one of LOCALES)
DEFAULT_LOCALE=fa

NEXT_PUBLIC_SITE_ID=studioarman

NEXT_PUBLIC_DEFAULT_THEME=system

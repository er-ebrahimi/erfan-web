# Playwright E2E Test Environment Variables
# Copy to .env.local in the next/ directory (shared with Next.js)

# Base URL for the application under test (default: http://localhost:3000)
BASE_URL=http://localhost:3000

# ALTCHA secret (must match the one in your Next.js .env.local)
# Needed for contact form submission verification
ALTCHA_HMAC_SECRET=your-random-secret-here
